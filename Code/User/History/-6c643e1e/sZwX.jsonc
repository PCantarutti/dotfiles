{
    // ##################
    // ### BAR CONFIG ###
    // ##################
    "layer": "top",
    "position": "top",
    "height": 35,

    "modules-left":   ["hyprland/workspaces", "group/system", "group/media-controls"],
    "modules-center": ["group/dock"],
    "modules-right":  ["tray", "group/controls", "group/conection", "clock", "custom/power"],


    // ################
    // ### PROGRAMS ###
    // ################

    "tray": {
        "icon-size": 16,
        "spacing": 8,
        "show-passive-items": false
    },


    // #############
    // ### CLOCK ###
    // #############

    "clock": {
        "format": "{:%H:%M | %d/%m/%Y}",
        "format-alt": " {:%H:%M}",
        "tooltip": false
    },


    // ###############
    // ### BATTERY ###
    // ###############

    "battery": {
        "format":          "  {icon} {capacity}% ",
        "format-charging": "  ¾▒Éï {capacity}% ",
        "format-plugged":  "  ´çª {capacity}% ",
        "format-alt":      "  {icon}  {time} ",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
        "states": {
            "warning":  30,
            "critical": 15
        }
    },


    // ###############
    // ### NETWORK ###
    // ###############

    "network": {
        "format-wifi":       " ¾░û® {signalStrength}%  ",
        "format-disconnected": " ¾░û¬  ",
        "format-disabled":   " ¾░û¬  ",
        "format-ethernet":   " Connected ¯¢ä  ",
        "tooltip-format":    "{essid} ({signalStrength}%)",
        "on-click":          "~/.config/waybar/scripts/wifi-menu.sh",
        "on-click-right":    "sh -c 'sleep 0.1 && nm-applet --indicator &'"
    },


    // ###############
    // ### VOLUME  ###
    // ###############

    "pulseaudio": {
        "format":       " {icon} {volume}%",
        "format-muted": "¾░Øƒ Mudo",
        "format-icons": {
            "default": ["¾░ò┐", "¾░ûÇ", "¾░ò¥"]
        }
    },


    // #################
    // ### BACKLIGHT ###
    // #################

    "backlight": {
        "format":       "  {icon} {percent}%",
        "format-icons": ["¾░â×", "¾░âƒ", "¾░âá"],
        "tooltip":      false
    },


    // #################
    // ### BLUETOOTH ###
    // #################

    "bluetooth": {
        "format":                   "¾░é»",
        "format-connected":         "¾░é░ {device_battery_percentage}%",
        "format-off":               "¾░é▓",
        "tooltip-format":           "Bluetooth desconectado",
        "tooltip-format-connected": "{device_alias} - {device_battery_percentage}%",
        "on-click":                 "~/.config/waybar/scripts/bluetooth-menu.sh"
    },


    // ####################
    // ### SYSTEM STATS ###
    // ####################

    "cpu": {
        "format":  "  ´ïø {usage}%",
        "tooltip": true
    },

    "memory": {
        "format": "  ¯┐à  {}%"
    },

    "temperature": {
        "hwmon-path":         "/sys/class/thermal/thermal_zone2/temp",
        "critical-threshold": 75,
        "format":             "  {icon} {temperatureC}┬░C ",
        "format-critical":    "  {icon} {temperatureC}┬░C ",
        "format-icons":       ["´ïï", "´ïë", "´ïç"]
    },

    // #################
    // ### SCREENSHOT ##
    // #################

    "custom/screenshot": {
        "format": "  ¾░╣æ ",
        "tooltip": false,
        "on-click": "~/.config/waybar/scripts/screenshot.sh"
    },


    // ####################
    // ### NOTIFICATION ###
    // ####################

    "custom/notification": {
        "tooltip": false,
        "format":  "  {icon} ",
        "format-icons": {
            "notification":     "¾░éÜ",
            "none":             "¾░é£",
            "dnd-notification": "¾░éø",
            "dnd-none":         "¾░éø"
        },
        "return-type": "json",
        "exec-if":     "which swaync-client",
        "exec":        "swaync-client -swb",
        "on-click":    "swaync-client -t -sw",
        "escape":      true
    },


    // #############
    // ### POWER ###
    // #############

    "custom/power": {
        "format":   "ÔÅ╗",
        "tooltip":  false,
        "on-click": "~/.config/waybar/scripts/power-menu.sh"
    },


    // #######################
    // ### MEDIA CONTROLS  ###
    // #######################

    "custom/media": {
        "exec":       "~/.config/waybar/scripts/media-info.sh",
        "interval":   2,
        "max-length": 30,
        "on-click":   "playerctl play-pause",
        "tooltip":    false
    },

    "custom/prev": {
        "format":   "ÔÅ«",
        "on-click": "playerctl previous",
        "tooltip":  false
    },

    "custom/play": {
        "format":   "{}",
        "exec":     "playerctl status 2>/dev/null | sed 's/Playing/ÔÅ©/;s/Paused/ÔûÂ/;s/Stopped/ÔÅ╣/'",
        "interval": 1,
        "on-click": "playerctl play-pause",
        "tooltip":  false
    },

    "custom/next": {
        "format":   "ÔÅ¡",
        "on-click": "playerctl next",
        "tooltip":  false
    },

    // ###########################
    // ### BARRA DE APLICATIVOS ##
    // ###########################

    "custom/add-dock": {
        "format": "¾░Éò",
        "tooltip": false,
        "on-click": "~/.config/waybar/scripts/add-to-dock.sh"
    },

    "custom/firefox": {
    "format": "¾░ê╣",
    "on-click": "firefox",
    "tooltip-format": "Firefox",
    "tooltip": true
    },

    "custom/stremio": {
        "format": "´èƒ",
        "on-click": "flatpak run com.stremio.Stremio",
        "tooltip-format": "Stremio",
        "tooltip": true
    },

    "custom/files": {
        "format": "¾░ëï",
        "on-click": "nemo",
        "tooltip-format": "Arquivos",
        "tooltip": true
    },

    "custom/discord": {
        "format": "´ç┐",
        "on-click": "discord",
        "tooltip-format": "Discord",
        "tooltip": true
    },

        "custom/code": {
        "format": "¾░¿×",
        "on-click": "code",
        "tooltip-format": "VS Code",
        "tooltip": true
    },

        "custom/spotify": {
        "format": "´å╝",
        "on-click": "spotify",
        "tooltip-format": "Spotify",
        "tooltip": true
    },

    // ############
    // ### GROUPS ##
    // ############

    "group/media-controls": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration":    300,
            "children-class":         "media-drawer",
            "transition-left-to-right": true
        },
        "modules": ["custom/media", "custom/prev", "custom/play", "custom/next"]
    },

    "group/system": {
        "orientation": "horizontal",
        "modules": ["cpu", "memory", "temperature"]
    },

    "group/controls": {
        "orientation": "horizontal",
        "modules": ["pulseaudio", "backlight", "custom/screenshot","custom/notification"]
    },

    "group/conection": {
        "orientation": "horizontal",
        "modules": ["network", "bluetooth", "battery"]
    },

    "group/dock": {
        "orientation": "horizontal",
        "modules": ["custom/firefox", "custom/code", "custom/files", "custom/stremio", "custom/spotify", "custom/discord"]
    }
}
